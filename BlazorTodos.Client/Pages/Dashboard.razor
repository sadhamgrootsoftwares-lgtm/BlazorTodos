@page "/dashboard"
@attribute [Authorize]

@inject BlazorTodos.Client.Services.TodoService TodoService

<div class="container py-4">

    <div class="text-center mb-5">
        <h2 class="fw-bold text-primary">Dashboard</h2>
        <p class="text-muted">Overview of your task activity</p>
    </div>

    @if (todos == null)
    {
        <div class="text-center mt-5">
            <div class="spinner-border text-primary"></div>
        </div>
    }
    else
    {
        <div class="row g-4">

            <!-- Total Tasks -->
            <div class="col-md-4">
                <div class="card dashboard-card bg-gradient-primary text-white shadow-sm">
                    <div class="card-body text-center">
                        <div class="icon-circle bg-white text-primary mb-3">
                            <i class="bi bi-list-task"></i>
                        </div>
                        <h6>Total Tasks</h6>
                        <h2 class="fw-bold">@todos.Count</h2>
                    </div>
                </div>
            </div>

            <!-- Completed -->
            <div class="col-md-4">
                <div class="card dashboard-card bg-gradient-success text-white shadow-sm">
                    <div class="card-body text-center">
                        <div class="icon-circle bg-white text-success mb-3">
                            <i class="bi bi-check-circle-fill"></i>
                        </div>
                        <h6>Completed</h6>
                        <h2 class="fw-bold">@todos.Count(t => t.IsCompleted)</h2>
                    </div>
                </div>
            </div>

            <!-- Pending -->
            <div class="col-md-4">
                <div class="card dashboard-card bg-gradient-warning text-dark shadow-sm">
                    <div class="card-body text-center">
                        <div class="icon-circle bg-white text-warning mb-3">
                            <i class="bi bi-clock-fill"></i>
                        </div>
                        <h6>Pending</h6>
                        <h2 class="fw-bold">@todos.Count(t => !t.IsCompleted)</h2>
                    </div>
                </div>
            </div>

        </div>
    }

</div>

@code {
    private List<TodoResponseDto>? todos;

    protected override async Task OnInitializedAsync()
    {
        todos = await TodoService.GetTodos();
    }
}
