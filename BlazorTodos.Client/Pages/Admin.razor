@page "/admin"
@attribute [Authorize(Roles = "Admin")]

<div class="container py-5">

    <div class="text-center mb-5">
        <h2 class="fw-bold text-primary">Admin Dashboard</h2>
        <p class="text-muted">Manage system settings and administrative controls</p>
    </div>

    <div class="row g-4">

        <!-- Manage Users -->
        <div class="col-md-4">
            <div class="card shadow-sm border-0 admin-card">
                <div class="card-body text-center">
                    <div class="icon-circle bg-primary text-white mb-3">
                        <i class="bi bi-people-fill"></i>
                    </div>
                    <h5 class="fw-bold">Manage Users</h5>
                    <p class="text-muted small">
                        View, edit and manage registered users.
                    </p>
                    <a href="/users" class="btn btn-outline-primary btn-sm">
                        Open
                    </a>
                </div>
            </div>
        </div>

        <!-- Manage Products -->
        <div class="col-md-4">
            <div class="card shadow-sm border-0 admin-card">
                <div class="card-body text-center">
                    <div class="icon-circle bg-success text-white mb-3">
                        <i class="bi bi-box-seam"></i>
                    </div>
                    <h5 class="fw-bold">Manage Products</h5>
                    <p class="text-muted small">
                        Add, update and delete products.
                    </p>
                    <a href="/products" class="btn btn-outline-success btn-sm">
                        Open
                    </a>
                </div>
            </div>
        </div>

        <!-- Settings -->
        <div class="col-md-4">
            <div class="card shadow-sm border-0 admin-card">
                <div class="card-body text-center">
                    <div class="icon-circle bg-warning text-white mb-3">
                        <i class="bi bi-gear-fill"></i>
                    </div>
                    <h5 class="fw-bold">System Settings</h5>
                    <p class="text-muted small">
                        Configure application level settings.
                    </p>
                    <button class="btn btn-outline-warning btn-sm">
                        Configure
                    </button>
                </div>
            </div>
        </div>

    </div>

</div>
