@page "/admin"
@attribute [Authorize(Roles = "Admin")]

<div class="container py-5">

    <div class="text-center mb-5">
        <h2 class="fw-bold text-primary">Admin Dashboard</h2>
        <p class="text-muted">Administrative controls for Todo Application</p>
    </div>

    <div class="row g-4">

        <!-- Manage Users -->
        <div class="col-md-4">
            <div class="card shadow-sm border-0">
                <div class="card-body text-center">
                    <div class="mb-3">
                        <i class="bi bi-people-fill fs-1 text-primary"></i>
                    </div>
                    <h5 class="fw-bold">Manage Users</h5>
                    <p class="text-muted small">
                        View and manage registered users.
                    </p>
                    <a href="/users" class="btn btn-outline-primary btn-sm">
                        Open
                    </a>
                </div>
            </div>
        </div>

        <!-- View All Tasks -->
        <div class="col-md-4">
            <div class="card shadow-sm border-0">
                <div class="card-body text-center">
                    <div class="mb-3">
                        <i class="bi bi-list-check fs-1 text-success"></i>
                    </div>
                    <h5 class="fw-bold">All Tasks</h5>
                    <p class="text-muted small">
                        Monitor all user tasks in the system.
                    </p>
                    <a href="/todos" class="btn btn-outline-success btn-sm">
                        View
                    </a>
                </div>
            </div>
        </div>

        <!-- System Info -->
        <div class="col-md-4">
            <div class="card shadow-sm border-0">
                <div class="card-body text-center">
                    <div class="mb-3">
                        <i class="bi bi-gear-fill fs-1 text-warning"></i>
                    </div>
                    <h5 class="fw-bold">System Info</h5>
                    <p class="text-muted small">
                        Application configuration and health status.
                    </p>
                    <button class="btn btn-outline-warning btn-sm">
                        View
                    </button>
                </div>
            </div>
        </div>

    </div>

</div>