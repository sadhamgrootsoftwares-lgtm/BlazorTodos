@page "/"
@attribute [Authorize]

<div class="container py-5">

    <!-- Page Header -->
    <div class="text-center mb-5">
        <h2 class="fw-bold text-primary">Blazor Todos</h2>
        <p class="text-muted">Modern Full-Stack Task Management Application</p>
    </div>

    <div class="row g-4">

        <!-- Tech Stack Card -->
        <div class="col-md-6">
            <div class="card shadow-lg border-0 info-card h-100">
                <div class="card-body text-center p-4">
                    <div class="icon-circle bg-primary text-white mb-3">
                        <i class="bi bi-stack"></i>
                    </div>

                    <h4 class="fw-bold mb-3">Tech Stack</h4>

                    <ul class="list-group list-group-flush">
                        <li class="list-group-item">Blazor WebAssembly</li>
                        <li class="list-group-item">ASP.NET Core Web API</li>
                        <li class="list-group-item">Entity Framework Core</li>
                        <li class="list-group-item">Bootstrap 5</li>
                        <li class="list-group-item">C#</li>
                        <li class="list-group-item">SQL Server</li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- About Project Card -->
        <div class="col-md-6">
            <div class="card shadow-lg border-0 info-card h-100">
                <div class="card-body text-center p-4">
                    <div class="icon-circle bg-success text-white mb-3">
                        <i class="bi bi-info-circle-fill"></i>
                    </div>

                    <h4 class="fw-bold mb-3">About This Project</h4>

                    <p class="text-muted">
                        BlazorTodos is a modern task management application built with
                        Blazor WebAssembly and ASP.NET Core Web API. It includes
                        authentication, secure CRUD operations, and a responsive UI powered
                        by Bootstrap. The project demonstrates clean architecture,
                        best practices in full-stack .NET development, and interactive web design.
                    </p>
                </div>
            </div>
        </div>

    </div>

</div>